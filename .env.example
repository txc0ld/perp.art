# ============================================================================
# tryperpetual.art - environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. Anything prefixed NEXT_PUBLIC_ is exposed to the browser; keep
# everything else server-only (never prefix secrets with NEXT_PUBLIC_).
#
# The app currently runs fully on a deterministic in-memory mock layer
# (src/lib/mock-data.ts), so NONE of these are required for local dev today.
# They are the complete set you will need as you wire each layer to live
# infrastructure (contracts, indexer, orderbook, storage, wallets).
# ============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://tryperpetual.art
NEXT_PUBLIC_APP_ENV=development            # development | preview | production

# ---------------------------------------------------------------------------
# Wallet connection (WalletConnect / Reown AppKit, wagmi/viem)
# Get a project id at https://cloud.reown.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---------------------------------------------------------------------------
# RPC endpoints - one per supported chain (Alchemy / Infura / QuickNode / etc.)
# EVM chains (permanence-native, Forever Library deploys here):
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_ZORA=https://rpc.zora.energy
NEXT_PUBLIC_RPC_SHAPE=https://shape-mainnet.g.alchemy.com/v2/YOUR_KEY
# Non-EVM chains (indexed + traded; native storage):
NEXT_PUBLIC_RPC_SOLANA=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_RPC_TEZOS=https://mainnet.api.tez.ie
NEXT_PUBLIC_RPC_FLOW=https://rest-mainnet.onflow.org

# Optional testnet RPCs for staging (Sepolia, Base Sepolia, etc.)
RPC_SEPOLIA=
RPC_BASE_SEPOLIA=

# ---------------------------------------------------------------------------
# Deployed contracts (per chain). Fill after deploying contracts/.
# Forever Library = the shared ERC-721 + ERC-2981 + URI-sharding mint contract.
# Settlement = the Seaport-compatible, royalty-enforcing exchange.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FOREVER_LIBRARY_ETHEREUM=0x
NEXT_PUBLIC_FOREVER_LIBRARY_BASE=0x
NEXT_PUBLIC_SETTLEMENT_ETHEREUM=0x
NEXT_PUBLIC_SETTLEMENT_BASE=0x
# ethfs (onchain file store) addresses used by the onchain proof shard:
NEXT_PUBLIC_ETHFS_ETHEREUM=0x
NEXT_PUBLIC_ETHFS_BASE=0x
# Conduit / zone addresses if forking Seaport:
SEAPORT_CONDUIT_KEY=
SEAPORT_ZONE_ADDRESS=

# Protocol fee recipient + rate (bps). Mirrors PROTOCOL_FEE_BPS in code (225 = 2.25%).
NEXT_PUBLIC_PROTOCOL_FEE_BPS=225
PROTOCOL_FEE_RECIPIENT=0x

# ---------------------------------------------------------------------------
# Cross-chain settlement (escrow bridge for NFT-for-NFT cross-chain swaps)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BRIDGE_CONTRACT=0x
BRIDGE_RELAYER_URL=
BRIDGE_RELAYER_KEY=
NEXT_PUBLIC_BRIDGE_FEE_ETH=0.0009

# ---------------------------------------------------------------------------
# Indexer + Orderbook API (the centralized, rebuildable-from-public-data layer)
# Swap src/lib/mock-data.ts accessors for calls to this API. Schema: docs/INDEXER_SPEC.md
# ---------------------------------------------------------------------------
NEXT_PUBLIC_INDEXER_URL=https://api.tryperpetual.art
NEXT_PUBLIC_ORDERBOOK_URL=https://api.tryperpetual.art/orders
INDEXER_API_KEY=
DATABASE_URL=postgres://user:pass@host:5432/perpetual
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Permanent storage providers (the four shards)
# ---------------------------------------------------------------------------
# IPFS pinning (Pinata / web3.storage / Filebase)
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
# Arweave (pay-once permanent)
ARWEAVE_WALLET_JWK=                          # JSON key (server-only)
NEXT_PUBLIC_ARWEAVE_GATEWAY=https://arweave.net/
# Irys (Datachain bundler)
IRYS_PRIVATE_KEY=
NEXT_PUBLIC_IRYS_GATEWAY=https://gateway.irys.xyz/
# Optional high-res CDN performance shard
NEXT_PUBLIC_CDN_BASE=https://cdn.tryperpetual.art

# ---------------------------------------------------------------------------
# ENS / identity resolution
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ENS_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---------------------------------------------------------------------------
# Permanence verification service (read-only; resolves + hashes each shard)
# ---------------------------------------------------------------------------
VERIFIER_URL=https://verify.tryperpetual.art
VERIFIER_API_KEY=

# ---------------------------------------------------------------------------
# Fiat on-ramp (optional, v2) + analytics + email
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ONRAMP_PROVIDER=                 # e.g. stripe-crypto | moonpay
ONRAMP_API_KEY=
NEXT_PUBLIC_ANALYTICS_ID=
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Deploy / CI (used by scripts + Hardhat/Foundry when deploying contracts)
# NEVER commit a funded private key. Use a dedicated deployer.
# ---------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
